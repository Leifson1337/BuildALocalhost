# ============================================================================
# GENERATED Kubernetes manifests — Profile: {{ profile_name }} | Engine: {{ engine_id }}
# Apply with: kubectl apply -f manifests.yaml
# Scope: core serving path (see installer/k8s_renderer.py docstring).
# Set real secret values and an ingress host before applying.
# ============================================================================
apiVersion: v1
kind: Namespace
metadata:
  name: {{ namespace }}
---
apiVersion: v1
kind: Secret
metadata:
  name: ai-stack-secrets
  namespace: {{ namespace }}
type: Opaque
stringData:
  POSTGRES_PASSWORD: "CHANGE_ME"
  LITELLM_MASTER_KEY: "sk-CHANGE_ME"
  WEBUI_SECRET_KEY: "CHANGE_ME"
  HF_TOKEN: ""
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: litellm-config
  namespace: {{ namespace }}
data:
  config.yaml: |
    model_list:
{% for m in models %}
      - model_name: {{ m.name }}
        litellm_params:
          model: openai/{{ m.model }}
          api_base: http://{{ m.service }}:{{ m.port }}/v1
          api_key: "dummy"
{% endfor %}
    general_settings:
      master_key: os.environ/LITELLM_MASTER_KEY
      database_url: os.environ/DATABASE_URL
    router_settings:
      routing_strategy: latency-based-routing
      num_retries: 2
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: postgres-pvc
  namespace: {{ namespace }}
spec:
  accessModes: [ReadWriteOnce]
  resources:
    requests:
      storage: 10Gi
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: postgres
  namespace: {{ namespace }}
spec:
  replicas: 1
  selector:
    matchLabels: {app: postgres}
  template:
    metadata:
      labels: {app: postgres}
    spec:
      containers:
        - name: postgres
          image: postgres:16
          env:
            - {name: POSTGRES_DB, value: ai_stack}
            - {name: POSTGRES_USER, value: ai_stack}
            - name: POSTGRES_PASSWORD
              valueFrom: {secretKeyRef: {name: ai-stack-secrets, key: POSTGRES_PASSWORD}}
          ports: [{containerPort: 5432}]
          volumeMounts: [{name: data, mountPath: /var/lib/postgresql/data}]
      volumes:
        - name: data
          persistentVolumeClaim: {claimName: postgres-pvc}
---
apiVersion: v1
kind: Service
metadata: {name: postgres, namespace: {{ namespace }}}
spec:
  selector: {app: postgres}
  ports: [{port: 5432, targetPort: 5432}]
---
apiVersion: apps/v1
kind: Deployment
metadata: {name: redis, namespace: {{ namespace }}}
spec:
  replicas: 1
  selector: {matchLabels: {app: redis}}
  template:
    metadata: {labels: {app: redis}}
    spec:
      containers:
        - name: redis
          image: redis:7
          args: ["redis-server", "--appendonly", "yes"]
          ports: [{containerPort: 6379}]
---
apiVersion: v1
kind: Service
metadata: {name: redis, namespace: {{ namespace }}}
spec:
  selector: {app: redis}
  ports: [{port: 6379, targetPort: 6379}]
{% for m in models %}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ m.service }}
  namespace: {{ namespace }}
  labels: {app: {{ m.service }}, role: "{{ m.role }}"}
spec:
  replicas: 1
  selector: {matchLabels: {app: {{ m.service }}}}
  template:
    metadata: {labels: {app: {{ m.service }}}}
    spec:
{% if engine_gpu_required %}
      nodeSelector:
        {{ gpu_resource_key }}.present: "true"
      tolerations:
        - {key: {{ gpu_resource_key }}, operator: Exists, effect: NoSchedule}
{% endif %}
      containers:
        - name: engine
          image: {{ engine_image }}
{% if m.k8s_args %}
          args:
{% for arg in m.k8s_args %}
            - "{{ arg }}"
{% endfor %}
{% endif %}
          env:
            - name: HF_TOKEN
              valueFrom: {secretKeyRef: {name: ai-stack-secrets, key: HF_TOKEN}}
            - {name: HF_HOME, value: /hf-cache}
          ports: [{containerPort: {{ m.port }}}]
{% if engine_gpu_required %}
          resources:
            limits:
              {{ gpu_resource_key }}: {{ gpu_per_pod }}
{% endif %}
          volumeMounts:
            - {name: hf-cache, mountPath: /hf-cache}
      volumes:
        - name: hf-cache
          emptyDir: {sizeLimit: 200Gi}
---
apiVersion: v1
kind: Service
metadata: {name: {{ m.service }}, namespace: {{ namespace }}}
spec:
  selector: {app: {{ m.service }}}
  ports: [{port: {{ m.port }}, targetPort: {{ m.port }}}]
{% endfor %}
---
apiVersion: apps/v1
kind: Deployment
metadata: {name: litellm, namespace: {{ namespace }}}
spec:
  replicas: 1
  selector: {matchLabels: {app: litellm}}
  template:
    metadata: {labels: {app: litellm}}
    spec:
      containers:
        - name: litellm
          image: ghcr.io/berriai/litellm:main-stable
          args: ["--config", "/app/config.yaml", "--port", "4000"]
          env:
            - name: LITELLM_MASTER_KEY
              valueFrom: {secretKeyRef: {name: ai-stack-secrets, key: LITELLM_MASTER_KEY}}
            - name: POSTGRES_PASSWORD
              valueFrom: {secretKeyRef: {name: ai-stack-secrets, key: POSTGRES_PASSWORD}}
            - {name: DATABASE_URL, value: "postgresql://ai_stack:$(POSTGRES_PASSWORD)@postgres:5432/ai_stack"}
            - {name: REDIS_HOST, value: redis}
          ports: [{containerPort: 4000}]
          volumeMounts: [{name: config, mountPath: /app/config.yaml, subPath: config.yaml}]
      volumes:
        - name: config
          configMap: {name: litellm-config}
---
apiVersion: v1
kind: Service
metadata: {name: litellm, namespace: {{ namespace }}}
spec:
  selector: {app: litellm}
  ports: [{port: 4000, targetPort: 4000}]
{% if ui_open_webui %}
---
apiVersion: apps/v1
kind: Deployment
metadata: {name: open-webui, namespace: {{ namespace }}}
spec:
  replicas: 1
  selector: {matchLabels: {app: open-webui}}
  template:
    metadata: {labels: {app: open-webui}}
    spec:
      containers:
        - name: open-webui
          image: ghcr.io/open-webui/open-webui:main
          env:
            - {name: OPENAI_API_BASE_URL, value: "http://litellm:4000/v1"}
            - name: OPENAI_API_KEY
              valueFrom: {secretKeyRef: {name: ai-stack-secrets, key: LITELLM_MASTER_KEY}}
          ports: [{containerPort: 8080}]
---
apiVersion: v1
kind: Service
metadata: {name: open-webui, namespace: {{ namespace }}}
spec:
  selector: {app: open-webui}
  ports: [{port: 8080, targetPort: 8080}]
{% endif %}
{% if uses_traefik %}
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: ai-stack-ingress
  namespace: {{ namespace }}
  annotations:
    kubernetes.io/ingress.class: "nginx"
spec:
  rules:
    - host: "{{ domains.api or 'api.example.com' }}"
      http:
        paths:
          - path: /
            pathType: Prefix
            backend: {service: {name: litellm, port: {number: 4000}}}
{% if ui_open_webui %}
    - host: "{{ domains.webui or 'chat.example.com' }}"
      http:
        paths:
          - path: /
            pathType: Prefix
            backend: {service: {name: open-webui, port: {number: 8080}}}
{% endif %}
{% endif %}
{% if rag.enabled %}
# ---- RAG parity ----
---
apiVersion: apps/v1
kind: Deployment
metadata: {name: vectordb, namespace: {{ namespace }}}
spec:
  replicas: 1
  selector: {matchLabels: {app: vectordb}}
  template:
    metadata: {labels: {app: vectordb}}
    spec:
      containers:
        - name: vectordb
          image: {{ rag.vector_db.image }}
          ports: [{containerPort: {{ rag.vector_db.port }}}]
---
apiVersion: v1
kind: Service
metadata: {name: vectordb, namespace: {{ namespace }}}
spec: {selector: {app: vectordb}, ports: [{port: {{ rag.vector_db.port }}, targetPort: {{ rag.vector_db.port }}}]}
---
apiVersion: apps/v1
kind: Deployment
metadata: {name: embeddings, namespace: {{ namespace }}}
spec:
  replicas: 1
  selector: {matchLabels: {app: embeddings}}
  template:
    metadata: {labels: {app: embeddings}}
    spec:
{% if engine_gpu_required %}
      nodeSelector: { {{ gpu_resource_key }}.present: "true" }
      tolerations: [{key: {{ gpu_resource_key }}, operator: Exists, effect: NoSchedule}]
{% endif %}
      containers:
        - name: tei
          image: {{ rag.embeddings.image }}
          args: ["--model-id", "{{ rag.embeddings.model }}", "--port", "{{ rag.embeddings.port }}"]
          ports: [{containerPort: {{ rag.embeddings.port }}}]
{% if engine_gpu_required %}
          resources: {limits: { {{ gpu_resource_key }}: 1 }}
{% endif %}
---
apiVersion: v1
kind: Service
metadata: {name: embeddings, namespace: {{ namespace }}}
spec: {selector: {app: embeddings}, ports: [{port: {{ rag.embeddings.port }}, targetPort: {{ rag.embeddings.port }}}]}
---
apiVersion: apps/v1
kind: Deployment
metadata: {name: reranker, namespace: {{ namespace }}}
spec:
  replicas: 1
  selector: {matchLabels: {app: reranker}}
  template:
    metadata: {labels: {app: reranker}}
    spec:
{% if engine_gpu_required %}
      nodeSelector: { {{ gpu_resource_key }}.present: "true" }
      tolerations: [{key: {{ gpu_resource_key }}, operator: Exists, effect: NoSchedule}]
{% endif %}
      containers:
        - name: tei-rerank
          image: {{ rag.reranker.image }}
          args: ["--model-id", "{{ rag.reranker.model }}", "--port", "{{ rag.reranker.port }}"]
          ports: [{containerPort: {{ rag.reranker.port }}}]
{% if engine_gpu_required %}
          resources: {limits: { {{ gpu_resource_key }}: 1 }}
{% endif %}
---
apiVersion: v1
kind: Service
metadata: {name: reranker, namespace: {{ namespace }}}
spec: {selector: {app: reranker}, ports: [{port: {{ rag.reranker.port }}, targetPort: {{ rag.reranker.port }}}]}
{% endif %}
{% if mcp.enabled %}
# ---- MCP gateway parity (internal only; no Ingress) ----
---
apiVersion: apps/v1
kind: Deployment
metadata: {name: mcp-gateway, namespace: {{ namespace }}}
spec:
  replicas: 1
  selector: {matchLabels: {app: mcp-gateway}}
  template:
    metadata: {labels: {app: mcp-gateway}}
    spec:
      containers:
        - name: mcp-gateway
          image: {{ mcp.gateway_image }}
          ports: [{containerPort: {{ mcp.gateway_port }}}]
---
apiVersion: v1
kind: Service
metadata: {name: mcp-gateway, namespace: {{ namespace }}}
spec: {selector: {app: mcp-gateway}, ports: [{port: {{ mcp.gateway_port }}, targetPort: {{ mcp.gateway_port }}}]}
{% endif %}
{% if monitoring %}
# ---- Monitoring parity ----
---
apiVersion: v1
kind: ConfigMap
metadata: {name: prometheus-config, namespace: {{ namespace }}}
data:
  prometheus.yml: |
    global: {scrape_interval: 15s}
    scrape_configs:
      - job_name: dcgm
        static_configs: [{targets: ["dcgm-exporter:9400"]}]
      - job_name: litellm
        metrics_path: /metrics
        static_configs: [{targets: ["litellm:4000"]}]
---
apiVersion: apps/v1
kind: Deployment
metadata: {name: prometheus, namespace: {{ namespace }}}
spec:
  replicas: 1
  selector: {matchLabels: {app: prometheus}}
  template:
    metadata: {labels: {app: prometheus}}
    spec:
      containers:
        - name: prometheus
          image: prom/prometheus:v3.0.1
          args: ["--config.file=/etc/prometheus/prometheus.yml"]
          ports: [{containerPort: 9090}]
          volumeMounts: [{name: cfg, mountPath: /etc/prometheus}]
      volumes:
        - name: cfg
          configMap: {name: prometheus-config}
---
apiVersion: v1
kind: Service
metadata: {name: prometheus, namespace: {{ namespace }}}
spec: {selector: {app: prometheus}, ports: [{port: 9090, targetPort: 9090}]}
---
apiVersion: apps/v1
kind: Deployment
metadata: {name: grafana, namespace: {{ namespace }}}
spec:
  replicas: 1
  selector: {matchLabels: {app: grafana}}
  template:
    metadata: {labels: {app: grafana}}
    spec:
      containers:
        - name: grafana
          image: grafana/grafana:11.4.0
          env:
            - name: GF_SECURITY_ADMIN_PASSWORD
              valueFrom: {secretKeyRef: {name: ai-stack-secrets, key: LITELLM_MASTER_KEY}}
          ports: [{containerPort: 3000}]
---
apiVersion: v1
kind: Service
metadata: {name: grafana, namespace: {{ namespace }}}
spec: {selector: {app: grafana}, ports: [{port: 3000, targetPort: 3000}]}
{% if runtime_kind == "cuda" %}
---
apiVersion: apps/v1
kind: DaemonSet
metadata: {name: dcgm-exporter, namespace: {{ namespace }}}
spec:
  selector: {matchLabels: {app: dcgm-exporter}}
  template:
    metadata: {labels: {app: dcgm-exporter}}
    spec:
      nodeSelector: { {{ gpu_resource_key }}.present: "true" }
      tolerations: [{key: {{ gpu_resource_key }}, operator: Exists, effect: NoSchedule}]
      containers:
        - name: dcgm-exporter
          image: nvcr.io/nvidia/k8s/dcgm-exporter:3.3.9-3.6.1-ubuntu22.04
          ports: [{containerPort: 9400}]
          securityContext: {capabilities: {add: ["SYS_ADMIN"]}}
---
apiVersion: v1
kind: Service
metadata: {name: dcgm-exporter, namespace: {{ namespace }}}
spec: {selector: {app: dcgm-exporter}, ports: [{port: 9400, targetPort: 9400}]}
{% endif %}
{% endif %}
