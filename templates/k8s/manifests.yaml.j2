# ============================================================================
# GENERATED Kubernetes manifests — Profile: {{ profile_name }} | Engine: {{ engine_id }}
# Apply with: kubectl apply -f manifests.yaml
# Scope: core serving path (see installer/k8s_renderer.py docstring).
# Set real secret values and an ingress host before applying.
# ============================================================================
apiVersion: v1
kind: Namespace
metadata:
  name: {{ namespace }}
---
apiVersion: v1
kind: Secret
metadata:
  name: ai-stack-secrets
  namespace: {{ namespace }}
type: Opaque
stringData:
  POSTGRES_PASSWORD: "CHANGE_ME"
  LITELLM_MASTER_KEY: "sk-CHANGE_ME"
  WEBUI_SECRET_KEY: "CHANGE_ME"
  HF_TOKEN: ""
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: litellm-config
  namespace: {{ namespace }}
data:
  config.yaml: |
    model_list:
{% for m in models %}
      - model_name: {{ m.name }}
        litellm_params:
          model: openai/{{ m.model }}
          api_base: http://{{ m.service }}:{{ m.port }}/v1
          api_key: "dummy"
{% endfor %}
    general_settings:
      master_key: os.environ/LITELLM_MASTER_KEY
      database_url: os.environ/DATABASE_URL
    router_settings:
      routing_strategy: latency-based-routing
      num_retries: 2
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: postgres-pvc
  namespace: {{ namespace }}
spec:
  accessModes: [ReadWriteOnce]
  resources:
    requests:
      storage: 10Gi
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: postgres
  namespace: {{ namespace }}
spec:
  replicas: 1
  selector:
    matchLabels: {app: postgres}
  template:
    metadata:
      labels: {app: postgres}
    spec:
      containers:
        - name: postgres
          image: postgres:16
          env:
            - {name: POSTGRES_DB, value: ai_stack}
            - {name: POSTGRES_USER, value: ai_stack}
            - name: POSTGRES_PASSWORD
              valueFrom: {secretKeyRef: {name: ai-stack-secrets, key: POSTGRES_PASSWORD}}
          ports: [{containerPort: 5432}]
          volumeMounts: [{name: data, mountPath: /var/lib/postgresql/data}]
      volumes:
        - name: data
          persistentVolumeClaim: {claimName: postgres-pvc}
---
apiVersion: v1
kind: Service
metadata: {name: postgres, namespace: {{ namespace }}}
spec:
  selector: {app: postgres}
  ports: [{port: 5432, targetPort: 5432}]
---
apiVersion: apps/v1
kind: Deployment
metadata: {name: redis, namespace: {{ namespace }}}
spec:
  replicas: 1
  selector: {matchLabels: {app: redis}}
  template:
    metadata: {labels: {app: redis}}
    spec:
      containers:
        - name: redis
          image: redis:7
          args: ["redis-server", "--appendonly", "yes"]
          ports: [{containerPort: 6379}]
---
apiVersion: v1
kind: Service
metadata: {name: redis, namespace: {{ namespace }}}
spec:
  selector: {app: redis}
  ports: [{port: 6379, targetPort: 6379}]
{% for m in models %}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ m.service }}
  namespace: {{ namespace }}
  labels: {app: {{ m.service }}, role: "{{ m.role }}"}
spec:
  replicas: 1
  selector: {matchLabels: {app: {{ m.service }}}}
  template:
    metadata: {labels: {app: {{ m.service }}}}
    spec:
      containers:
        - name: engine
          image: {{ engine_image }}
{% if m.k8s_args %}
          args:
{% for arg in m.k8s_args %}
            - "{{ arg }}"
{% endfor %}
{% endif %}
          env:
            - name: HF_TOKEN
              valueFrom: {secretKeyRef: {name: ai-stack-secrets, key: HF_TOKEN}}
            - {name: HF_HOME, value: /hf-cache}
          ports: [{containerPort: {{ m.port }}}]
{% if engine_gpu_required %}
          resources:
            limits:
              {{ gpu_resource_key }}: {{ gpu_per_pod }}
{% endif %}
          volumeMounts:
            - {name: hf-cache, mountPath: /hf-cache}
      volumes:
        - name: hf-cache
          emptyDir: {sizeLimit: 200Gi}
---
apiVersion: v1
kind: Service
metadata: {name: {{ m.service }}, namespace: {{ namespace }}}
spec:
  selector: {app: {{ m.service }}}
  ports: [{port: {{ m.port }}, targetPort: {{ m.port }}}]
{% endfor %}
---
apiVersion: apps/v1
kind: Deployment
metadata: {name: litellm, namespace: {{ namespace }}}
spec:
  replicas: 1
  selector: {matchLabels: {app: litellm}}
  template:
    metadata: {labels: {app: litellm}}
    spec:
      containers:
        - name: litellm
          image: ghcr.io/berriai/litellm:main-stable
          args: ["--config", "/app/config.yaml", "--port", "4000"]
          env:
            - name: LITELLM_MASTER_KEY
              valueFrom: {secretKeyRef: {name: ai-stack-secrets, key: LITELLM_MASTER_KEY}}
            - name: POSTGRES_PASSWORD
              valueFrom: {secretKeyRef: {name: ai-stack-secrets, key: POSTGRES_PASSWORD}}
            - {name: DATABASE_URL, value: "postgresql://ai_stack:$(POSTGRES_PASSWORD)@postgres:5432/ai_stack"}
            - {name: REDIS_HOST, value: redis}
          ports: [{containerPort: 4000}]
          volumeMounts: [{name: config, mountPath: /app/config.yaml, subPath: config.yaml}]
      volumes:
        - name: config
          configMap: {name: litellm-config}
---
apiVersion: v1
kind: Service
metadata: {name: litellm, namespace: {{ namespace }}}
spec:
  selector: {app: litellm}
  ports: [{port: 4000, targetPort: 4000}]
{% if ui_open_webui %}
---
apiVersion: apps/v1
kind: Deployment
metadata: {name: open-webui, namespace: {{ namespace }}}
spec:
  replicas: 1
  selector: {matchLabels: {app: open-webui}}
  template:
    metadata: {labels: {app: open-webui}}
    spec:
      containers:
        - name: open-webui
          image: ghcr.io/open-webui/open-webui:main
          env:
            - {name: OPENAI_API_BASE_URL, value: "http://litellm:4000/v1"}
            - name: OPENAI_API_KEY
              valueFrom: {secretKeyRef: {name: ai-stack-secrets, key: LITELLM_MASTER_KEY}}
          ports: [{containerPort: 8080}]
---
apiVersion: v1
kind: Service
metadata: {name: open-webui, namespace: {{ namespace }}}
spec:
  selector: {app: open-webui}
  ports: [{port: 8080, targetPort: 8080}]
{% endif %}
{% if uses_traefik %}
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: ai-stack-ingress
  namespace: {{ namespace }}
  annotations:
    kubernetes.io/ingress.class: "nginx"
spec:
  rules:
    - host: "{{ domains.api or 'api.example.com' }}"
      http:
        paths:
          - path: /
            pathType: Prefix
            backend: {service: {name: litellm, port: {number: 4000}}}
{% if ui_open_webui %}
    - host: "{{ domains.webui or 'chat.example.com' }}"
      http:
        paths:
          - path: /
            pathType: Prefix
            backend: {service: {name: open-webui, port: {number: 8080}}}
{% endif %}
{% endif %}
