# GENERATED Authelia configuration — Profile: {{ profile_name }}
# Minimal single-factor file-based setup. Replace the user DB and policies for production.
theme: dark
server:
  address: "tcp://0.0.0.0:{{ auth.port }}"

log:
  level: info

authentication_backend:
  file:
    path: /config/users.yml         # provision users here (see Authelia docs)

access_control:
  default_policy: deny
  rules:
    - domain: "*.{{ domains.api or 'example.com' }}"
      policy: one_factor

session:
  name: authelia_session
  cookies:
    - domain: "{{ domains.api or 'example.com' }}"
      authelia_url: "https://auth.{{ domains.api or 'example.com' }}"
  redis:
    host: redis
    port: 6379

storage:
  local:
    path: /config/db.sqlite3

notifier:
  filesystem:
    filename: /config/notification.txt
