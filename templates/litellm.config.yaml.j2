# GENERATED LiteLLM config — Profile: {{ profile_name }}
# All UIs/clients talk to LiteLLM; engines stay on the internal network (ADR-0005).

model_list:
{% for m in deployments %}
  # data-parallel replicas share model_name -> LiteLLM load-balances across them
  - model_name: {{ m.name }}
    litellm_params:
      model: openai/{{ m.model }}
      api_base: http://{{ m.service }}:{{ m.port }}/v1
      api_key: "dummy"          # engine has no auth; it is internal-only
{% if m.role and m.role != "main" %}
    model_info: {role: {{ m.role }}}
{% endif %}
{% endfor %}
{% for e in endpoints %}
  # external/extra endpoint — reachable via this gateway as model '{{ e.name }}'
  - model_name: {{ e.name }}
    litellm_params:
      model: {{ e.litellm_model }}
{% if e.api_base %}
      api_base: {{ e.api_base }}
{% endif %}
      api_key: {{ e.api_key_ref }}
{% if e.mode and e.mode != "chat" %}
    model_info: {mode: {{ e.mode }}}
{% endif %}
{% endfor %}

general_settings:
  master_key: ${LITELLM_MASTER_KEY}
  database_url: ${DATABASE_URL}
{% if rate_limits %}
  # Per-key rate limiting (tune in LiteLLM admin / virtual keys).
  max_parallel_requests: 100
{% endif %}

router_settings:
  routing_strategy: latency-based-routing
  num_retries: 2
  timeout: 120
  redis_host: redis
  redis_port: 6379

litellm_settings:
  drop_params: true
  request_timeout: 600
{% if rate_limits %}
  max_budget: null
{% endif %}
