# ============================================================================
# GENERATED by Universal AI Stack Builder — do not edit by hand.
# Profile: {{ profile_name }} | Engine: {{ engine_id }} | Model: {{ model }}
# Regenerate with: python -m installer --profile {{ profile_name }}
# ============================================================================
name: ai-stack-{{ profile_name }}

networks:
  public: {}
  internal:
    internal: true
{% if monitoring %}
  monitoring:
    internal: true
{% endif %}

volumes:
  hf_cache: {}
  model_cache: {}
  postgres_data: {}
  redis_data: {}
  open_webui_data: {}
{% if monitoring %}
  grafana_data: {}
  prometheus_data: {}
{% endif %}

services:

{% if uses_traefik %}
  traefik:
    image: traefik:v3.2
    command:
      - "--api.dashboard=false"
      - "--providers.docker=true"
      - "--providers.docker.exposedbydefault=false"
      - "--providers.file.directory=/etc/traefik/dynamic"
      - "--entrypoints.web.address=:80"
      - "--entrypoints.websecure.address=:443"
      - "--entrypoints.web.http.redirections.entrypoint.to=websecure"
      - "--entrypoints.web.http.redirections.entrypoint.scheme=https"
{% if tls %}
      - "--certificatesresolvers.le.acme.tlschallenge=true"
      - "--certificatesresolvers.le.acme.email=${ACME_EMAIL}"
      - "--certificatesresolvers.le.acme.storage=/letsencrypt/acme.json"
{% endif %}
    ports:
      - "80:80"
      - "443:443"
    networks: [public, internal]
    volumes:
      # SECURITY (ADR-0009): read-only socket mount; replaced by docker-socket-proxy in Stage 2.
      - "/var/run/docker.sock:/var/run/docker.sock:ro"
      - "./configs/traefik:/etc/traefik/dynamic:ro"
      - "./data/letsencrypt:/letsencrypt"
    restart: unless-stopped
{% endif %}

  postgres:
    image: postgres:16
    environment:
      POSTGRES_DB: ai_stack
      POSTGRES_USER: ai_stack
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
    volumes:
      - postgres_data:/var/lib/postgresql/data
    networks: [internal]
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ai_stack"]
      interval: 10s
      timeout: 5s
      retries: 5
    restart: unless-stopped

  redis:
    image: redis:7
    command: ["redis-server", "--appendonly", "yes"]
    volumes:
      - redis_data:/data
    networks: [internal]
    restart: unless-stopped

  inference:
    image: {{ engine_image }}
    ipc: host
    shm_size: "{{ shm_size }}"
    environment:
      HF_TOKEN: ${HF_TOKEN:-}
      HUGGING_FACE_HUB_TOKEN: ${HF_TOKEN:-}
      HF_HOME: /hf-cache
{% if engine_command %}
    command:
{% for arg in engine_command %}
      - "{{ arg }}"
{% endfor %}
{% endif %}
    volumes:
      - hf_cache:/hf-cache
      - model_cache:/models
    networks: [internal]
{% if engine_gpu_required %}
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [gpu]
{% endif %}
    restart: unless-stopped

  litellm:
    image: ghcr.io/berriai/litellm:main-stable
    command: ["--config", "/app/config.yaml", "--port", "4000"]
    environment:
      DATABASE_URL: postgresql://ai_stack:${POSTGRES_PASSWORD}@postgres:5432/ai_stack
      LITELLM_MASTER_KEY: ${LITELLM_MASTER_KEY}
      REDIS_HOST: redis
      REDIS_PORT: "6379"
    volumes:
      - ./configs/litellm/config.yaml:/app/config.yaml:ro
    depends_on:
      postgres:
        condition: service_healthy
    networks: [internal{% if monitoring %}, monitoring{% endif %}]
{% if uses_traefik %}
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.litellm.rule=Host(`${API_DOMAIN}`)"
      - "traefik.http.routers.litellm.entrypoints=websecure"
{% if tls %}
      - "traefik.http.routers.litellm.tls.certresolver=le"
{% endif %}
      - "traefik.http.routers.litellm.middlewares=secure-headers@file{% if rate_limits %},ratelimit@file{% endif %}"
      - "traefik.http.services.litellm.loadbalancer.server.port=4000"
{% else %}
    ports:
      - "{{ bind }}:{{ litellm_port }}:4000"
{% endif %}
    restart: unless-stopped

{% if ui_open_webui %}
  open-webui:
    image: ghcr.io/open-webui/open-webui:main
    environment:
      OPENAI_API_BASE_URL: http://litellm:4000/v1
      OPENAI_API_KEY: ${LITELLM_MASTER_KEY}
      WEBUI_SECRET_KEY: ${WEBUI_SECRET_KEY}
    volumes:
      - open_webui_data:/app/backend/data
    depends_on: [litellm]
    networks: [internal]
{% if uses_traefik %}
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.openwebui.rule=Host(`${WEBUI_DOMAIN}`)"
      - "traefik.http.routers.openwebui.entrypoints=websecure"
{% if tls %}
      - "traefik.http.routers.openwebui.tls.certresolver=le"
{% endif %}
      - "traefik.http.services.openwebui.loadbalancer.server.port=8080"
{% else %}
    ports:
      - "{{ bind }}:{{ open_webui_port }}:8080"
{% endif %}
    restart: unless-stopped
{% endif %}

{% if monitoring %}
  prometheus:
    image: prom/prometheus:v3.0.1
    command: ["--config.file=/etc/prometheus/prometheus.yml"]
    volumes:
      - ./configs/prometheus/prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - prometheus_data:/prometheus
    networks: [monitoring]
    restart: unless-stopped

  grafana:
    image: grafana/grafana:11.4.0
    environment:
      GF_SECURITY_ADMIN_PASSWORD: ${GRAFANA_ADMIN_PASSWORD}
      GF_USERS_ALLOW_SIGN_UP: "false"
    volumes:
      - grafana_data:/var/lib/grafana
      - ./configs/grafana/provisioning:/etc/grafana/provisioning:ro
    networks: [monitoring{% if uses_traefik %}, internal{% endif %}]
    depends_on: [prometheus]
{% if uses_traefik %}
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.grafana.rule=Host(`${GRAFANA_DOMAIN}`)"
      - "traefik.http.routers.grafana.entrypoints=websecure"
{% if tls %}
      - "traefik.http.routers.grafana.tls.certresolver=le"
{% endif %}
      - "traefik.http.services.grafana.loadbalancer.server.port=3000"
{% endif %}
    restart: unless-stopped

  dcgm-exporter:
    image: nvcr.io/nvidia/k8s/dcgm-exporter:3.3.9-3.6.1-ubuntu22.04
    cap_add: [SYS_ADMIN]
    networks: [monitoring]
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [gpu]
    restart: unless-stopped

  node-exporter:
    image: prom/node-exporter:v1.8.2
    networks: [monitoring]
    pid: host
    volumes:
      - "/:/host:ro,rslave"
    command: ["--path.rootfs=/host"]
    restart: unless-stopped

  cadvisor:
    image: gcr.io/cadvisor/cadvisor:v0.49.1
    networks: [monitoring]
    volumes:
      - "/:/rootfs:ro"
      - "/var/run:/var/run:ro"
      - "/sys:/sys:ro"
      - "/var/lib/docker/:/var/lib/docker:ro"
    restart: unless-stopped
{% endif %}
