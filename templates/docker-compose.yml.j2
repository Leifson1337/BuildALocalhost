# ============================================================================
# GENERATED by Universal AI Stack Builder — do not edit by hand.
# Profile: {{ profile_name }} | Engine: {{ engine_id }} | Model: {{ model }}
# Regenerate with: python -m installer --profile {{ profile_name }}
# ============================================================================
name: ai-stack-{{ profile_name }}

networks:
  public: {}
  internal:
    internal: true
{% if monitoring %}
  monitoring:
    internal: true
{% endif %}

volumes:
  hf_cache: {}
  model_cache: {}
  postgres_data: {}
  redis_data: {}
  open_webui_data: {}
{% if monitoring %}
  grafana_data: {}
  prometheus_data: {}
{% endif %}
{% if rag.enabled %}
  hf_cache_embed: {}
{% if rag.vector_db.volume %}
  {{ rag.vector_db.volume }}: {}
{% endif %}
{% if rag.document_app == "anythingllm" %}
  anythingllm_data: {}
{% endif %}
{% endif %}
{% if auth.id == "authentik" %}
  authentik_media: {}
{% endif %}

services:

{% if uses_traefik %}
{% if docker_socket_proxy %}
  # SECURITY (ADR-0009): Traefik reaches Docker only via a read-only socket proxy.
  docker-socket-proxy:
    image: tecnativa/docker-socket-proxy:0.3.0
    environment:
      CONTAINERS: "1"
      SERVICES: "1"
      TASKS: "1"
      NETWORKS: "1"
      POST: "0"          # deny all write/POST operations
    volumes:
      - "/var/run/docker.sock:/var/run/docker.sock:ro"
    networks: [internal]
    restart: unless-stopped

{% endif %}
  traefik:
    image: traefik:v3.2
    command:
      - "--api.dashboard=false"
      - "--providers.docker=true"
      - "--providers.docker.exposedbydefault=false"
{% if docker_socket_proxy %}
      - "--providers.docker.endpoint=tcp://docker-socket-proxy:2375"
{% endif %}
      - "--providers.file.directory=/etc/traefik/dynamic"
      - "--entrypoints.web.address=:80"
      - "--entrypoints.websecure.address=:443"
      - "--entrypoints.web.http.redirections.entrypoint.to=websecure"
      - "--entrypoints.web.http.redirections.entrypoint.scheme=https"
{% if tls %}
      - "--certificatesresolvers.le.acme.tlschallenge=true"
      - "--certificatesresolvers.le.acme.email=${ACME_EMAIL}"
      - "--certificatesresolvers.le.acme.storage=/letsencrypt/acme.json"
{% endif %}
    ports:
      - "80:80"
      - "443:443"
    networks: [public, internal]
    volumes:
{% if not docker_socket_proxy %}
      # Residual risk: direct read-only socket mount (no proxy in this security profile).
      - "/var/run/docker.sock:/var/run/docker.sock:ro"
{% endif %}
      - "./configs/traefik:/etc/traefik/dynamic:ro"
      - "./data/letsencrypt:/letsencrypt"
{% if docker_socket_proxy %}
    depends_on: [docker-socket-proxy]
{% endif %}
    restart: unless-stopped
{% endif %}

  postgres:
    image: postgres:16
    environment:
      POSTGRES_DB: ai_stack
      POSTGRES_USER: ai_stack
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
    volumes:
      - postgres_data:/var/lib/postgresql/data
    networks: [internal]
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ai_stack"]
      interval: 10s
      timeout: 5s
      retries: 5
    restart: unless-stopped

  redis:
    image: redis:7
    command: ["redis-server", "--appendonly", "yes"]
    volumes:
      - redis_data:/data
    networks: [internal]
    restart: unless-stopped

{% for m in models %}
  # Inference engine for model '{{ m.name }}' (role: {{ m.role }})
  {{ m.service }}:
    image: {{ engine_image }}
    ipc: host
    shm_size: "{{ shm_size }}"
    environment:
      HF_TOKEN: ${HF_TOKEN:-}
      HUGGING_FACE_HUB_TOKEN: ${HF_TOKEN:-}
      HF_HOME: /hf-cache
{% if m.command %}
    command:
{% for arg in m.command %}
      - "{{ arg }}"
{% endfor %}
{% endif %}
    volumes:
      - hf_cache:/hf-cache
      - model_cache:/models
    networks: [internal]
{% if engine_gpu_required and runtime_kind == "cuda" %}
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [gpu]
{% elif engine_gpu_required and runtime_kind == "rocm" %}
    # AMD ROCm GPU access
    devices:
      - /dev/kfd
      - /dev/dri
    group_add: [video]
    security_opt: [seccomp=unconfined]
    cap_add: [SYS_PTRACE]
{% endif %}
    restart: unless-stopped

{% endfor %}

  litellm:
    image: ghcr.io/berriai/litellm:main-stable
    command: ["--config", "/app/config.yaml", "--port", "4000"]
    environment:
      DATABASE_URL: postgresql://ai_stack:${POSTGRES_PASSWORD}@postgres:5432/ai_stack
      LITELLM_MASTER_KEY: ${LITELLM_MASTER_KEY}
      REDIS_HOST: redis
      REDIS_PORT: "6379"
    volumes:
      - ./configs/litellm/config.yaml:/app/config.yaml:ro
    depends_on:
      postgres:
        condition: service_healthy
    networks: [internal{% if monitoring %}, monitoring{% endif %}]
{% if uses_traefik %}
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.litellm.rule=Host(`${API_DOMAIN}`)"
      - "traefik.http.routers.litellm.entrypoints=websecure"
{% if tls %}
      - "traefik.http.routers.litellm.tls.certresolver=le"
{% endif %}
      - "traefik.http.routers.litellm.middlewares=secure-headers@file{% if rate_limits %},ratelimit@file{% endif %}"
      - "traefik.http.services.litellm.loadbalancer.server.port=4000"
{% else %}
    ports:
      - "{{ bind }}:{{ litellm_port }}:4000"
{% endif %}
    restart: unless-stopped

{% if ui_open_webui %}
  open-webui:
    image: ghcr.io/open-webui/open-webui:main
    environment:
      OPENAI_API_BASE_URL: http://litellm:4000/v1
      OPENAI_API_KEY: ${LITELLM_MASTER_KEY}
      WEBUI_SECRET_KEY: ${WEBUI_SECRET_KEY}
    volumes:
      - open_webui_data:/app/backend/data
    depends_on: [litellm]
    networks: [internal]
{% if uses_traefik %}
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.openwebui.rule=Host(`${WEBUI_DOMAIN}`)"
      - "traefik.http.routers.openwebui.entrypoints=websecure"
{% if tls %}
      - "traefik.http.routers.openwebui.tls.certresolver=le"
{% endif %}
      - "traefik.http.services.openwebui.loadbalancer.server.port=8080"
{% else %}
    ports:
      - "{{ bind }}:{{ open_webui_port }}:8080"
{% endif %}
    restart: unless-stopped
{% endif %}

{% if monitoring %}
  prometheus:
    image: prom/prometheus:v3.0.1
    command: ["--config.file=/etc/prometheus/prometheus.yml"]
    volumes:
      - ./configs/prometheus/prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - prometheus_data:/prometheus
    networks: [monitoring]
    restart: unless-stopped

  grafana:
    image: grafana/grafana:11.4.0
    environment:
      GF_SECURITY_ADMIN_PASSWORD: ${GRAFANA_ADMIN_PASSWORD}
      GF_USERS_ALLOW_SIGN_UP: "false"
    volumes:
      - grafana_data:/var/lib/grafana
      - ./configs/grafana/provisioning:/etc/grafana/provisioning:ro
    networks: [monitoring{% if uses_traefik %}, internal{% endif %}]
    depends_on: [prometheus]
{% if uses_traefik %}
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.grafana.rule=Host(`${GRAFANA_DOMAIN}`)"
      - "traefik.http.routers.grafana.entrypoints=websecure"
{% if tls %}
      - "traefik.http.routers.grafana.tls.certresolver=le"
{% endif %}
      - "traefik.http.services.grafana.loadbalancer.server.port=3000"
{% endif %}
    restart: unless-stopped

{% if runtime_kind == "cuda" %}
  dcgm-exporter:               # NVIDIA GPU metrics (CUDA only)
    image: nvcr.io/nvidia/k8s/dcgm-exporter:3.3.9-3.6.1-ubuntu22.04
    cap_add: [SYS_ADMIN]
    networks: [monitoring]
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [gpu]
    restart: unless-stopped
{% endif %}

  node-exporter:
    image: prom/node-exporter:v1.8.2
    networks: [monitoring]
    pid: host
    volumes:
      - "/:/host:ro,rslave"
    command: ["--path.rootfs=/host"]
    restart: unless-stopped

  cadvisor:
    image: gcr.io/cadvisor/cadvisor:v0.49.1
    networks: [monitoring]
    volumes:
      - "/:/rootfs:ro"
      - "/var/run:/var/run:ro"
      - "/sys:/sys:ro"
      - "/var/lib/docker/:/var/lib/docker:ro"
    restart: unless-stopped
{% endif %}

{% if rag.enabled %}
  # --- RAG stack ------------------------------------------------------------
  vectordb:
    image: {{ rag.vector_db.image }}
{% if rag.vector_db.volume %}
    volumes:
      - {{ rag.vector_db.volume }}:/qdrant/storage
{% endif %}
    networks: [internal]
    restart: unless-stopped

  embeddings:
    image: {{ rag.embeddings.image }}
    command: ["--model-id", "${EMBEDDINGS_MODEL}", "--port", "{{ rag.embeddings.port }}"]
    environment:
      HF_TOKEN: ${HF_TOKEN:-}
    volumes:
      - hf_cache_embed:/data
    networks: [internal]
{% if runtime_kind == "cuda" %}
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: 1
              capabilities: [gpu]
{% elif runtime_kind == "rocm" %}
    devices: ["/dev/kfd", "/dev/dri"]
    group_add: [video]
{% endif %}
    restart: unless-stopped

  reranker:
    image: {{ rag.reranker.image }}
    command: ["--model-id", "${RERANKER_MODEL}", "--port", "{{ rag.reranker.port }}"]
    environment:
      HF_TOKEN: ${HF_TOKEN:-}
    networks: [internal]
{% if runtime_kind == "cuda" %}
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: 1
              capabilities: [gpu]
{% endif %}
    restart: unless-stopped

{% if rag.document_app == "anythingllm" %}
  anythingllm:
    image: {{ rag.anythingllm_image }}
    environment:
      LLM_PROVIDER: generic-openai
      GENERIC_OPEN_AI_BASE_PATH: http://litellm:4000/v1
      GENERIC_OPEN_AI_API_KEY: ${LITELLM_MASTER_KEY}
      GENERIC_OPEN_AI_MODEL_PREF: main-chat
      EMBEDDING_ENGINE: generic-openai
      EMBEDDING_BASE_PATH: http://embeddings:{{ rag.embeddings.port }}
      VECTOR_DB: {{ rag.vector_db.id }}
    volumes:
      - anythingllm_data:/app/server/storage
    depends_on: [litellm, vectordb, embeddings]
    networks: [internal]
{% if uses_traefik %}
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.anythingllm.rule=Host(`anythingllm.${API_DOMAIN}`)"
      - "traefik.http.routers.anythingllm.entrypoints=websecure"
{% if tls %}
      - "traefik.http.routers.anythingllm.tls.certresolver=le"
{% endif %}
      - "traefik.http.services.anythingllm.loadbalancer.server.port={{ rag.anythingllm_port }}"
{% endif %}
    restart: unless-stopped
{% endif %}
{% endif %}

{% if mcp.enabled %}
  # --- MCP gateway (deny-by-default; internal only; NEVER public) -----------
  mcp-gateway:
    image: {{ mcp.gateway_image }}
    command: ["--config", "/config/policies.yaml", "--port", "{{ mcp.gateway_port }}"]
    volumes:
      - ./configs/mcp/policies.yaml:/config/policies.yaml:ro
    networks: [internal]
    restart: unless-stopped
{% endif %}

{% if auth.service and auth.id == "authelia" %}
  # --- Auth: Authelia (forward-auth via Traefik) ----------------------------
  authelia:
    image: {{ auth.image }}
    volumes:
      - ./configs/authelia/configuration.yml:/config/configuration.yml:ro
    environment:
      AUTHELIA_JWT_SECRET: ${AUTHELIA_JWT_SECRET}
      AUTHELIA_SESSION_SECRET: ${AUTHELIA_SESSION_SECRET}
      AUTHELIA_STORAGE_ENCRYPTION_KEY: ${AUTHELIA_STORAGE_ENCRYPTION_KEY}
    depends_on: [redis]
    networks: [internal]
{% if uses_traefik %}
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.authelia.rule=Host(`auth.${API_DOMAIN}`)"
      - "traefik.http.routers.authelia.entrypoints=websecure"
{% if tls %}
      - "traefik.http.routers.authelia.tls.certresolver=le"
{% endif %}
      - "traefik.http.services.authelia.loadbalancer.server.port={{ auth.port }}"
      - "traefik.http.middlewares.authelia.forwardauth.address=http://authelia:{{ auth.port }}/api/verify?rd=https://auth.${API_DOMAIN}"
      - "traefik.http.middlewares.authelia.forwardauth.trustForwardHeader=true"
      - "traefik.http.middlewares.authelia.forwardauth.authResponseHeaders=Remote-User,Remote-Groups,Remote-Email"
{% endif %}
    restart: unless-stopped
{% endif %}

{% if auth.service and auth.id == "authentik" %}
  # --- Auth: Authentik (full IdP; server + worker) --------------------------
  authentik-server:
    image: {{ auth.image }}
    command: server
    environment:
      AUTHENTIK_SECRET_KEY: ${AUTHENTIK_SECRET_KEY}
      AUTHENTIK_POSTGRESQL__HOST: postgres
      AUTHENTIK_POSTGRESQL__USER: ai_stack
      AUTHENTIK_POSTGRESQL__PASSWORD: ${POSTGRES_PASSWORD}
      AUTHENTIK_POSTGRESQL__NAME: ai_stack
      AUTHENTIK_REDIS__HOST: redis
    volumes:
      - authentik_media:/media
    depends_on: [postgres, redis]
    networks: [internal]
{% if uses_traefik %}
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.authentik.rule=Host(`auth.${API_DOMAIN}`)"
      - "traefik.http.routers.authentik.entrypoints=websecure"
{% if tls %}
      - "traefik.http.routers.authentik.tls.certresolver=le"
{% endif %}
      - "traefik.http.services.authentik.loadbalancer.server.port={{ auth.port }}"
{% endif %}
    restart: unless-stopped

  authentik-worker:
    image: {{ auth.image }}
    command: worker
    environment:
      AUTHENTIK_SECRET_KEY: ${AUTHENTIK_SECRET_KEY}
      AUTHENTIK_POSTGRESQL__HOST: postgres
      AUTHENTIK_POSTGRESQL__USER: ai_stack
      AUTHENTIK_POSTGRESQL__PASSWORD: ${POSTGRES_PASSWORD}
      AUTHENTIK_POSTGRESQL__NAME: ai_stack
      AUTHENTIK_REDIS__HOST: redis
    volumes:
      - authentik_media:/media
    depends_on: [postgres, redis]
    networks: [internal]
    restart: unless-stopped
{% endif %}

{% if auth.service and auth.id == "keycloak" %}
  # --- Auth: Keycloak (IdP; uses shared Postgres) ---------------------------
  keycloak:
    image: {{ auth.image }}
    command: start
    environment:
      KC_DB: postgres
      KC_DB_URL: jdbc:postgresql://postgres:5432/ai_stack
      KC_DB_USERNAME: ai_stack
      KC_DB_PASSWORD: ${POSTGRES_PASSWORD}
      KC_HOSTNAME: auth.${API_DOMAIN}
      KC_PROXY_HEADERS: xforwarded
      KC_HTTP_ENABLED: "true"
      KEYCLOAK_ADMIN: admin
      KEYCLOAK_ADMIN_PASSWORD: ${KEYCLOAK_ADMIN_PASSWORD}
    depends_on: [postgres]
    networks: [internal]
{% if uses_traefik %}
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.keycloak.rule=Host(`auth.${API_DOMAIN}`)"
      - "traefik.http.routers.keycloak.entrypoints=websecure"
{% if tls %}
      - "traefik.http.routers.keycloak.tls.certresolver=le"
{% endif %}
      - "traefik.http.services.keycloak.loadbalancer.server.port={{ auth.port }}"
{% endif %}
    restart: unless-stopped
{% endif %}
