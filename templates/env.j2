# ============================================================================
# GENERATED .env — contains secrets. NEVER commit this file (it is git-ignored).
# Profile: {{ profile_name }}
# ============================================================================

# --- Model(s) / inference ----------------------------------------------------
{% for m in models %}
{{ m.env_var }}={{ m.model }}
{% endfor %}
# Shared parallelism/precision/batching (applied to every inference service).
# Auto-tuned for efficiency: {{ tuning_strategy }}
TENSOR_PARALLEL_SIZE={{ tensor_parallel_size }}
PIPELINE_PARALLEL_SIZE={{ pipeline_parallel_size }}
GPU_MEMORY_UTILIZATION={{ gpu_memory_utilization }}
MAX_MODEL_LEN={{ max_model_len }}
DTYPE={{ dtype }}
MAX_NUM_SEQS={{ max_num_seqs }}
MAX_NUM_BATCHED_TOKENS={{ max_num_batched_tokens }}
KV_CACHE_DTYPE={{ kv_cache_dtype }}

# --- Hugging Face ------------------------------------------------------------
# Required for gated models. Export before `docker compose up` or set here.
HF_TOKEN=

{% if endpoint_env_vars %}
# --- External endpoint API keys (fill in to enable those upstreams) -----------
{% for k in endpoint_env_vars %}
{{ k }}=
{% endfor %}
{% endif %}

# --- Secrets (auto-generated) ------------------------------------------------
POSTGRES_PASSWORD={{ secrets.POSTGRES_PASSWORD }}
LITELLM_MASTER_KEY={{ secrets.LITELLM_MASTER_KEY }}
WEBUI_SECRET_KEY={{ secrets.WEBUI_SECRET_KEY }}
{% if monitoring %}
GRAFANA_ADMIN_PASSWORD={{ secrets.GRAFANA_ADMIN_PASSWORD }}
{% endif %}

{% if rag.enabled %}
# --- RAG ---------------------------------------------------------------------
EMBEDDINGS_MODEL={{ rag.embeddings.model }}
RERANKER_MODEL={{ rag.reranker.model }}
{% endif %}

{% if auth.id == "authelia" %}
# --- Auth: Authelia ----------------------------------------------------------
AUTHELIA_JWT_SECRET={{ secrets.AUTHELIA_JWT_SECRET }}
AUTHELIA_SESSION_SECRET={{ secrets.AUTHELIA_SESSION_SECRET }}
AUTHELIA_STORAGE_ENCRYPTION_KEY={{ secrets.AUTHELIA_STORAGE_ENCRYPTION_KEY }}
{% endif %}
{% if auth.id == "authentik" %}
# --- Auth: Authentik ---------------------------------------------------------
AUTHENTIK_SECRET_KEY={{ secrets.AUTHENTIK_SECRET_KEY }}
{% endif %}
{% if auth.id == "keycloak" %}
# --- Auth: Keycloak ----------------------------------------------------------
KEYCLOAK_ADMIN_PASSWORD={{ secrets.KEYCLOAK_ADMIN_PASSWORD }}
{% endif %}
{% if observability_langfuse %}
# --- Observability: Langfuse -------------------------------------------------
LANGFUSE_NEXTAUTH_SECRET={{ secrets.LANGFUSE_NEXTAUTH_SECRET }}
LANGFUSE_SALT={{ secrets.LANGFUSE_SALT }}
{% endif %}

{% if uses_traefik %}
# --- Domains & TLS -----------------------------------------------------------
# Set real DNS names that point at this host before starting (TLS via ACME).
API_DOMAIN={{ domains.api or "api.example.com" }}
WEBUI_DOMAIN={{ domains.webui or "chat.example.com" }}
GRAFANA_DOMAIN={{ domains.grafana or "grafana.example.com" }}
ACME_EMAIL=admin@example.com
{% endif %}
