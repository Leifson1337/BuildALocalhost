# ============================================================================
# GENERATED .env — contains secrets. NEVER commit this file (it is git-ignored).
# Profile: {{ profile_name }}
# ============================================================================

# --- Model / inference -------------------------------------------------------
MAIN_MODEL={{ model }}
TENSOR_PARALLEL_SIZE={{ tensor_parallel_size }}
PIPELINE_PARALLEL_SIZE={{ pipeline_parallel_size }}
GPU_MEMORY_UTILIZATION={{ gpu_memory_utilization }}
MAX_MODEL_LEN={{ max_model_len }}
DTYPE={{ dtype }}

# --- Hugging Face ------------------------------------------------------------
# Required for gated models. Export before `docker compose up` or set here.
HF_TOKEN=

# --- Secrets (auto-generated) ------------------------------------------------
POSTGRES_PASSWORD={{ secrets.POSTGRES_PASSWORD }}
LITELLM_MASTER_KEY={{ secrets.LITELLM_MASTER_KEY }}
WEBUI_SECRET_KEY={{ secrets.WEBUI_SECRET_KEY }}
{% if monitoring %}
GRAFANA_ADMIN_PASSWORD={{ secrets.GRAFANA_ADMIN_PASSWORD }}
{% endif %}

{% if uses_traefik %}
# --- Domains & TLS -----------------------------------------------------------
# Set real DNS names that point at this host before starting (TLS via ACME).
API_DOMAIN={{ domains.api or "api.example.com" }}
WEBUI_DOMAIN={{ domains.webui or "chat.example.com" }}
GRAFANA_DOMAIN={{ domains.grafana or "grafana.example.com" }}
ACME_EMAIL=admin@example.com
{% endif %}
